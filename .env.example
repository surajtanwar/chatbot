# --- LLM provider ---------------------------------------------------------
# Default provider is OpenAI. Set your key here.
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# To swap to Anthropic instead, set:
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Session memory -------------------------------------------------------
# By default sessions live in-memory (lost when the process stops).
# Set a file path to persist sessions across restarts via SqliteSaver:
# PATHFINDER_DB=pathfinder.sqlite
